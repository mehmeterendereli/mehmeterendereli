# === Core App ===
NEXT_PUBLIC_APP_URL=https://velia.com.tr
NODE_ENV=development

# === Firebase / GCP ===
GCP_PROJECT_ID=
GCP_REGION=europe-west1
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=

# === Pub/Sub Topics ===
PUBSUB_TOPIC_JOB_CREATED=job.created
PUBSUB_TOPIC_SCENE_GENERATED=scene.generated
PUBSUB_TOPIC_SCENE_QA_PASSED=scene.qa_passed
PUBSUB_TOPIC_SCENE_TTS_READY=scene.tts_ready
PUBSUB_TOPIC_VIDEO_RENDER_READY=video.render_ready
PUBSUB_TOPIC_VIDEO_RENDERED=video.rendered
PUBSUB_TOPIC_VIDEO_SCHEDULED=video.scheduled
PUBSUB_TOPIC_VIDEO_PUBLISHED=video.published
PUBSUB_TOPIC_VIDEO_FAILED=video.failed

# === Cloud Storage (R2/S3 compatible) ===
ASSETS_BUCKET=velia-assets
RENDERS_BUCKET=velia-renders
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# === External Providers ===
BANANA_API_KEY=
BANANA_MODEL_KEY=
GPT_MINI_API_KEY=
ELEVENLABS_API_KEY=

# === YouTube ===
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
