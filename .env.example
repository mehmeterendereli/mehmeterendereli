# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# === Observability ===
SENTRY_DSN=
LOG_LEVEL=info

# === Security ===
JWT_SECRET=
