{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://velia.com.tr/schemas/firestore.schema.json",
  "title": "Firestore Collections & Field Shapes (MVP)",
  "type": "object",
  "properties": {
    "users": {
      "type": "object",
      "description": "End-user profile and plan state",
      "properties": {
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "timezone": { "type": "string", "examples": ["Europe/Istanbul"] },
        "credits": {
          "type": "object",
          "properties": {
            "current": { "type": "integer", "minimum": 0 },
            "rollover": { "type": "integer", "minimum": 0 }
          },
          "required": ["current", "rollover"]
        },
        "automation": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "slots": {
              "type": "array",
              "items": { "type": "string", "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$" },
              "maxItems": 3
            }
          },
          "required": ["enabled", "slots"]
        }
      },
      "required": ["plan", "timezone", "credits", "automation"]
    },

    "plans": {
      "type": "object",
      "description": "Plan catalog",
      "properties": {
        "name": { "type": "string" },
        "monthlyCredits": { "type": "integer", "minimum": 0 },
        "parallelism": { "type": "integer", "minimum": 1 },
        "watermark": { "type": "boolean" },
        "resolution": { "type": "string", "enum": ["720p", "1080p"] }
      },
      "required": ["name", "monthlyCredits", "parallelism", "watermark", "resolution"]
    },

    "projects": {
      "type": "object",
      "description": "User presets for generation",
      "properties": {
        "userId": { "type": "string" },
        "niche": { "type": "string" },
        "langs": { "type": "array", "items": { "type": "string", "enum": ["tr", "en"] } },
        "stylePresetId": { "type": "string" },
        "voicePresetId": { "type": "string" },
        "musicProfile": { "type": "string" },
        "format": { "type": "string", "enum": ["9:16"] },
        "sceneCount": { "type": "integer", "enum": [6] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "niche", "langs", "stylePresetId", "voicePresetId", "musicProfile", "format", "sceneCount"]
    },

    "channels": {
      "type": "object",
      "description": "Connected distribution channels (YouTube)",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["youtube"] },
        "oauthTokens": { "type": "string", "description": "Encrypted JSON string" },
        "quotaMeta": { "type": "object" }
      },
      "required": ["userId", "type", "oauthTokens"]
    },

    "jobs": {
      "type": "object",
      "description": "Video generation jobs",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "sceneCount": { "type": "integer", "minimum": 1 },
        "computeMode": { "type": "string", "enum": ["economy", "balance"] },
        "status": { "type": "string", "enum": ["pending", "running", "rendering", "scheduled", "published", "failed", "manual_review"] },
        "attempts": { "type": "integer", "minimum": 0 },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "errorCode": { "type": "string" }
      },
      "required": ["userId", "projectId", "sceneCount", "computeMode", "status", "createdAt"]
    },

    "scenes": {
      "type": "object",
      "description": "Subcollection under jobs/{jobId}/scenes/{sceneIndex}",
      "properties": {
        "prompt": { "type": "string" },
        "seed": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "generating", "qa", "tts", "ready", "failed"] },
        "qaScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "attempts": { "type": "integer", "minimum": 0, "maximum": 3 },
        "imageUrl": { "type": "string", "format": "uri" },
        "ttsUrl": { "type": "string", "format": "uri" }
      },
      "required": ["prompt", "status", "attempts"]
    },

    "assets": {
      "type": "object",
      "description": "Generated artifacts linked to a job",
      "properties": {
        "jobId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "tts", "music", "video"] },
        "url": { "type": "string", "format": "uri" },
        "signedUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "type", "url"]
    },

    "credit_ledger": {
      "type": "object",
      "description": "Idempotent credit movements",
      "properties": {
        "userId": { "type": "string" },
        "jobId": { "type": "string" },
        "sceneIndex": { "type": "integer" },
        "type": { "type": "string", "enum": ["IMAGE", "REGEN", "REFUND", "RESERVE", "RELEASE"] },
        "delta": { "type": "integer", "enum": [-1, 1, -6, 6] },
        "ts": { "type": "string", "format": "date-time" },
        "idempotencyKey": { "type": "string" }
      },
      "required": ["userId", "type", "delta", "ts", "idempotencyKey"]
    },

    "schedules": {
      "type": "object",
      "description": "User scheduling preferences",
      "properties": {
        "userId": { "type": "string" },
        "tz": { "type": "string" },
        "slots": { "type": "array", "items": { "type": "string" } },
        "automationEnabled": { "type": "boolean" }
      },
      "required": ["userId", "tz", "slots", "automationEnabled"]
    },

    "metrics_daily": {
      "type": "object",
      "description": "Aggregated daily metrics",
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "avgE2E": { "type": "number" },
        "failRate": { "type": "number" },
        "regenRate": { "type": "number" },
        "costPerVideo": { "type": "number" }
      },
      "required": ["date"]
    },

    "notifications": {
      "type": "object",
      "description": "User notifications",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "object" },
        "read": { "type": "boolean" },
        "ts": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "payload", "read", "ts"]
    },

    "audit_logs": {
      "type": "object",
      "description": "Admin and user audit trail",
      "properties": {
        "userId": { "type": ["string", "null"] },
        "action": { "type": "string" },
        "detail": { "type": "string" },
        "ts": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "ts"]
    }
  }
}

